# Postgres connection string. Story 1.2 wires Neon via the Vercel-Neon Marketplace integration;
# locally, point this at a personal Neon branch or a local Postgres instance.
DATABASE_URL=

# Sentry (Story 4.3). Leave empty in development unless explicitly enabled.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# Toggle Sentry in dev (Story 4.3 default: disabled in development).
# NEXT_PUBLIC_SENTRY_ENABLED=false
